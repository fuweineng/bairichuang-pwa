  {"id": "math-126", "type": "choice", "subject": "math", "difficulty": 2, "grade": 8, "knowledgeTags": ["二元一次方程组"], "question": "方程组 3x+y=10, x-y=2 的解中 x+y=_____", "options": ["4", "6", "8", "10"], "answer": "6", "explanation": "相加：4x=12→x=3，代入：3-y=2→y=1，所以x+y=4"},
  {"id": "math-127", "type": "choice", "subject": "math", "difficulty": 1, "grade": 8, "knowledgeTags": ["平面直角坐标系"], "question": "若点P在第四象限，则点P的坐标特点是_____", "options": ["x>0,y>0", "x>0,y<0", "x<0,y>0", "x<0,y<0"], "answer": "x>0,y<0", "explanation": "第四象限：x>0（正），y<0（负）"},
